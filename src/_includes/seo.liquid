{% comment %}
  SEO + social preview meta tags.
  Reads from frontmatter (title, excerpt, image, date, tags, author, ogType)
  and falls back to site-level defaults from _data/site.js.
{% endcomment %}

{%- assign _pageTitle = title | default: site.title -%}
{%- if title -%}
  {%- assign _fullTitle = title | append: " - " | append: site.title -%}
{%- else -%}
  {%- assign _fullTitle = site.title -%}
{%- endif -%}
{%- assign _description = excerpt | default: description | default: site.description -%}
{%- assign _canonical = site.url | append: page.url -%}
{%- assign _author = author | default: site.author -%}
{%- if ogType -%}
  {%- assign _ogType = ogType -%}
{%- elsif tags and tags contains "posts" -%}
  {%- assign _ogType = "article" -%}
{%- else -%}
  {%- assign _ogType = "website" -%}
{%- endif -%}

{% comment %}
  Resolve image: `image` may be an absolute path ("/foo.jpg"), an absolute URL
  ("https://..."), or a bare filename relative to the page's URL.
  LinkedIn (and some other scrapers) reject WebP for og:image and time out
  on multi-MB originals, so we swap a .webp extension for the resized
  sibling produced by scripts/generate-og-jpegs.js (`<name>.og.jpg`).
{% endcomment %}
{%- if image -%}
  {%- assign _ogImage = image | replace: ".webp", ".og.jpg" -%}
  {%- if _ogImage | startsWith: "http" -%}
    {%- assign _imageUrl = _ogImage -%}
  {%- elsif _ogImage | startsWith: "/" -%}
    {%- assign _imageUrl = site.url | append: _ogImage -%}
  {%- else -%}
    {%- assign _imageUrl = site.url | append: page.url | append: _ogImage -%}
  {%- endif -%}
{%- elsif site.defaultImage -%}
  {%- assign _imageUrl = site.url | append: site.defaultImage -%}
{%- endif -%}

<title>{{ _fullTitle }}</title>
<meta name="description" content="{{ _description }}">
<meta name="author" content="{{ _author }}">
<meta name="robots" content="index, follow">
<link rel="canonical" href="{{ _canonical }}">

<meta property="og:site_name" content="{{ site.title }}">
<meta property="og:locale" content="en_US">
<meta property="og:type" content="{{ _ogType }}">
<meta property="og:title" content="{{ _fullTitle }}">
<meta property="og:description" content="{{ _description }}">
<meta property="og:url" content="{{ _canonical }}">
{%- if _imageUrl %}
<meta property="og:image" content="{{ _imageUrl }}">
<meta property="og:image:alt" content="{{ imageAlt | default: _pageTitle }}">
{%- endif %}

{%- if _ogType == "article" %}
{%- if date %}
<meta property="article:published_time" content="{{ date | toISO }}">
{%- endif %}
<meta property="article:author" content="{{ _author }}">
{%- if tags %}{%- for tag in tags %}{% if tag != "posts" %}
<meta property="article:tag" content="{{ tag }}">{% endif %}{%- endfor %}{%- endif %}
{%- endif %}

{%- if _imageUrl %}
  {%- assign _twitterCard = "summary_large_image" -%}
{%- else %}
  {%- assign _twitterCard = "summary" -%}
{%- endif %}
<meta name="twitter:card" content="{{ _twitterCard }}">
<meta name="twitter:title" content="{{ _fullTitle }}">
<meta name="twitter:description" content="{{ _description }}">
{%- if _imageUrl %}
<meta name="twitter:image" content="{{ _imageUrl }}">
{%- endif %}
